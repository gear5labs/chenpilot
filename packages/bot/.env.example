TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
DISCORD_BOT_TOKEN=your_discord_bot_token_here
API_BASE_URL=http://localhost:2333

# Dashboard URL (defaults to API_BASE_URL/dashboard)
DASHBOARD_URL=http://localhost:2333/dashboard

# Stellar network for /validate command
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# #147: GitHub release announcements
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret
BOT_WEBHOOK_PORT=3001
DISCORD_ANNOUNCEMENT_CHANNEL_ID=
TELEGRAM_ANNOUNCEMENT_CHAT_ID=

# Transaction thread logging (optional) - when enabled, the bot will create per-user threads
# in the configured channel and post detailed transaction logs there.
DISCORD_TRANSACTION_LOG_THREADS_ENABLED=true
DISCORD_TRANSACTION_LOG_CHANNEL_ID=
# Auto-archive duration for created threads (minutes). Default: 10080 (7 days)
DISCORD_TRANSACTION_THREAD_ARCHIVE_MINUTES=10080
